# ── 資料庫 ──────────────────────────────────────
# Railway / Supabase 提供的連線字串
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/xiaowo_db"

# ── Bot 同步更新網站快取 ─────────────────────────
REVALIDATE_SECRET="use-the-same-secret-as-linebot-rental"
LINEBOT_URL="https://your-linebot-rental.onrender.com"
NEXT_RUNTIME="nodejs"

# ── 管理金鑰（需與 linebot-rental 的 ADMIN_KEY 一致，供後台頁尾設定等寫入用）──
ADMIN_KEY="use-the-same-key-as-linebot-rental"

# ── NextAuth ─────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-key-change-in-production"

# ── OAuth 第三方登入 ──────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
LINE_CLIENT_ID=""
LINE_CLIENT_SECRET=""

# ── 車牌自動辨識（停車場後台 /parking，用 Claude 視覺模型）──
ANTHROPIC_API_KEY=""

# ── Cloudinary 圖片儲存 ──────────────────────────
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""

# ── Google Maps ──────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_KEY=""

# ── Email (SendGrid) ─────────────────────────────
SENDGRID_API_KEY=""
EMAIL_FROM="noreply@xiaowo.com.tw"
