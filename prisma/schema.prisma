// prisma/schema.prisma
// 小蝸出租 統一資料庫 Schema（網站 + LINE Bot 共用）

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// 網站使用者 (租客 + 房東 + 管理員)
// ─────────────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  phone         String?   @unique
  passwordHash  String?
  role          UserRole  @default(TENANT)

  name          String
  handle        String?   @unique
  avatar        String?
  bio           String?
  lineId        String?
  verified      Boolean   @default(false)

  totalListings Int       @default(0)
  avgRating     Float?
  reviewCount   Int       @default(0)
  yearsActive   Int       @default(0)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  properties    Property[]
  favorites     Favorite[]
  sentMessages  Message[]     @relation("SentMessages")
  receivedMessages Message[]  @relation("ReceivedMessages")
  bookingsAsTenant Booking[]  @relation("TenantBookings")
  reviews       Review[]
  accounts      Account[]
  sessions      Session[]

  @@index([email])
  @@index([handle])
  @@index([role])
  @@map("users")
}

enum UserRole {
  TENANT
  LANDLORD
  ADMIN
}

// ─────────────────────────────────────────────
// 房東（獨立租戶，多房東架構核心）
// 每個房東有自己的後台、房源、用戶、未來綁自己的 LINE Bot
// ─────────────────────────────────────────────
model Landlord {
  id            String    @id @default(cuid())
  name          String                          // 房東名稱（後台顯示）
  email         String    @unique               // 登入帳號
  passwordHash  String                          // 登入密碼（bcrypt）
  phone         String?
  avatar        String?

  // 後台存取金鑰（給 LINE Bot 後台用，類似之前的 ADMIN_KEY）
  adminKey      String    @unique

  // 階段 B 預留：房東自己的 LINE Bot 設定
  lineChannelSecret      String?
  lineChannelToken       String?
  lineBotName            String?
  lineOfficialId         String?   // LINE 官方帳號 Basic ID / Premium ID（例：@xiaowo）
  notifyLineUserId       String?   // 房東接收預約/維修通知的 LINE User ID
  richMenuConfig         String?   @db.Text   // 圖文選單設定（JSON）
  richMenuId             String?   // 已套用的 LINE Rich Menu ID
  richMenuEnabled        Boolean   @default(false)  // 選單是否開啟
  siteName               String?   // 房東官網名稱
  siteLogo               String?   // 房東官網 LOGO 圖片網址
  botTextConfig          String?   @db.Text   // Bot 自訂文字（JSON）
  botEnabled             Boolean   @default(true)   // Bot 是否啟用
  features               String?   @db.Text   // 功能模組開關（JSON）
  source                 String    @unique @default(cuid())  // 該房東用戶的來源標記

  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  properties    Property[]
  tenants       Tenant[]
  bookings      Booking[]
  repairs       Repair[]
  communities   Community[]

  @@index([email])
  @@index([adminKey])
  @@map("landlords")
}

// ─────────────────────────────────────────────
// LINE Bot 用戶（從 LINE 官方帳號來的用戶）
// ─────────────────────────────────────────────
model Tenant {
  id            String    @id @default(cuid())
  lineUserId    String
  name          String?
  customName    String?                      // 房東自訂備註名稱
  avatarUrl     String?
  statusMessage String?
  phone         String?
  propertyId    String?
  moveInDate    DateTime?
  rentDue       Int       @default(5)        // 每月幾號繳租
  isActive      Boolean   @default(true)
  source        String    @default("main")   // Bot 來源鍵（主 Bot=main；房東 Bot=landlordId）
  landlordId    String?                       // 歸屬房東
  createdAt     DateTime  @default(now())

  landlord   Landlord? @relation(fields: [landlordId], references: [id])
  property   Property? @relation("TenantResidence", fields: [propertyId], references: [id])
  bookings   Booking[]
  repairs    Repair[]

  @@index([landlordId])
  @@unique([lineUserId, source])
}

// ─────────────────────────────────────────────
// NextAuth (OAuth)
// ─────────────────────────────────────────────
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("sessions")
}

// ─────────────────────────────────────────────
// 房源（網站刊登 + Bot 查詢共用）
// ─────────────────────────────────────────────
model Property {
  id          String         @id @default(cuid())
  landlordId  String
  landlord    User           @relation(fields: [landlordId], references: [id])

  ownerId     String?                          // 多房東架構：歸屬的 Landlord
  owner       Landlord?      @relation(fields: [ownerId], references: [id])

  title       String
  type        PropertyType
  status      PropertyStatus @default(PENDING)
  featured     Boolean       @default(false)  // 主站精選（總管理員控制，未來廣告欄位）
  siteFeatured Boolean       @default(false)  // 房東官網精選（房東自己控制，與 featured 分開）
  description String         @db.Text

  city        String
  district    String
  address     String
  lat         Float?
  lng         Float?

  size        Float
  floor       String?
  totalFloors Int?

  price       Int
  deposit     String         @default("兩個月")
  mgmtFee     Int            @default(0)

  inclWifi    Boolean        @default(false)
  inclWater   Boolean        @default(false)
  inclCable   Boolean        @default(false)

  electricType  String?      // 電費計算方式：'meter'=台電度數, 'flat'=固定金額, 'included'=含在租金
  electricRate  Float?       // 每度電費（electricType=meter 時使用）
  electricFlat  Int?         // 固定電費金額（electricType=flat 時使用）
  cleaningFee   Int?         // 清潔費

  allowPets   Boolean        @default(false)
  allowCook   Boolean        @default(false)
  allowShortTerm Boolean     @default(false)
  welcomeStudent Boolean     @default(true)

  availableFrom DateTime?    // 即將釋出日期（status=PAUSED 時使用）

  boostPlan   BoostPlan      @default(NONE)
  boostUntil  DateTime?

  viewCount   Int            @default(0)
  favoriteCount Int          @default(0)

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  deletedAt   DateTime?

  images      PropertyImage[]
  amenities   PropertyAmenity[]
  tags        PropertyTag[]
  favorites   Favorite[]
  bookings    Booking[]
  reviews     Review[]
  messages    Message[]
  lineTenants Tenant[]       @relation("TenantResidence")
  repairs     Repair[]

  communityId String?
  community   Community?     @relation(fields: [communityId], references: [id])

  @@index([landlordId])
  @@index([ownerId])
  @@index([city, district])
  @@index([status])
  @@index([price])
  @@index([type])
  @@index([featured])
  @@index([siteFeatured])
  @@map("properties")
}

// ─────────────────────────────────────────────
// 社區（房源群組）
// ─────────────────────────────────────────────
model Community {
  id          String     @id @default(cuid())
  ownerId     String?
  owner       Landlord?  @relation(fields: [ownerId], references: [id])
  name        String
  description String     @default("") @db.Text
  photos      String     @default("[]") @db.Text
  mapUrl      String?
  properties  Property[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("communities")
}

// ─────────────────────────────────────────────
// 網站全域設定（logo、輪播圖等）
// ─────────────────────────────────────────────
model SiteSetting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @default(now()) @updatedAt

  @@map("site_settings")
}

enum PropertyType {
  SUITE
  ROOM
  WHOLE_FLOOR
  SHARED_SUITE
  STUDIO
  STORE
  OFFICE
  LIVE_OFFICE
  FACTORY
  PARKING
  LAND
  OTHER
}

enum PropertyStatus {
  PENDING
  AVAILABLE
  RENTED
  PAUSED
  REJECTED
  COMING_SOON
  INACTIVE
}

enum BoostPlan {
  NONE
  BASIC
  PREMIUM
}

// ─────────────────────────────────────────────
// 房源照片
// ─────────────────────────────────────────────
model PropertyImage {
  id          String   @id @default(cuid())
  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  url         String
  cloudinaryId String?
  order       Int      @default(0)
  isCover     Boolean  @default(false)
  width       Int?
  height      Int?

  createdAt   DateTime @default(now())

  @@index([propertyId])
  @@map("property_images")
}

// ─────────────────────────────────────────────
// 房源設施
// ─────────────────────────────────────────────
model PropertyAmenity {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  name       String

  @@unique([propertyId, name])
  @@index([propertyId])
  @@map("property_amenities")
}

// ─────────────────────────────────────────────
// 房源標籤（可租補、免仲介費等行銷標籤）
// ─────────────────────────────────────────────
model PropertyTag {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  name       String   // 例：'可租補', '免仲介費', '獨洗曬', '垃圾代收', '機車位'

  @@unique([propertyId, name])
  @@index([propertyId])
  @@map("property_tags")
}

// ─────────────────────────────────────────────
// 收藏
// ─────────────────────────────────────────────
model Favorite {
  id         String   @id @default(cuid())
  userId     String
  propertyId String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, propertyId])
  @@index([userId])
  @@map("favorites")
}

// ─────────────────────────────────────────────
// 看房預約（網站用戶 或 LINE 用戶皆可預約）
// ─────────────────────────────────────────────
model Booking {
  id         String        @id @default(cuid())
  propertyId String
  property   Property      @relation(fields: [propertyId], references: [id])

  // 網站用戶（二擇一）
  tenantId   String?
  tenant     User?         @relation("TenantBookings", fields: [tenantId], references: [id])

  // LINE 用戶（二擇一）
  lineUserId String?
  lineUser   Tenant?       @relation(fields: [lineUserId], references: [id])

  date       DateTime
  timeslot   String        // "14:00" 或 "10:00-11:00"
  status     BookingStatus @default(PENDING)
  note       String?
  rejectReason String?

  // 網頁訪客預約（不需登入）
  visitorName   String?
  visitorPhone  String?
  visitorLineId String?
  landlordId String?                       // 歸屬房東
  landlord   Landlord?     @relation(fields: [landlordId], references: [id])

  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([propertyId])
  @@index([tenantId])
  @@index([lineUserId])
  @@index([landlordId])
  @@index([status])
  @@map("bookings")
}

enum BookingStatus {
  PENDING
  CONFIRMED
  REJECTED
  CANCELLED
  COMPLETED
}

// ─────────────────────────────────────────────
// 維修回報（LINE Bot）
// ─────────────────────────────────────────────
model Repair {
  id          String       @id @default(cuid())
  lineUserId  String
  propertyId  String
  title       String
  description String
  status      RepairStatus @default(PENDING)
  photoUrl    String?
  landlordId  String?                      // 歸屬房東
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  lineUser    Tenant   @relation(fields: [lineUserId], references: [id])
  property    Property @relation(fields: [propertyId], references: [id])
  landlord    Landlord? @relation(fields: [landlordId], references: [id])

  @@index([lineUserId])
  @@index([propertyId])
  @@index([landlordId])
  @@map("repairs")
}

enum RepairStatus {
  PENDING
  IN_PROGRESS
  DONE
}

// ─────────────────────────────────────────────
// 站內訊息（網站，預留功能）
// ─────────────────────────────────────────────
model Message {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  propertyId String?

  sender     User     @relation("SentMessages", fields: [senderId], references: [id])
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
  property   Property? @relation(fields: [propertyId], references: [id])

  content    String   @db.Text
  readAt     DateTime?
  createdAt  DateTime @default(now())

  @@index([senderId])
  @@index([receiverId])
  @@index([propertyId])
  @@map("messages")
}

// ─────────────────────────────────────────────
// 評價（網站，預留功能）
// ─────────────────────────────────────────────
model Review {
  id         String   @id @default(cuid())
  propertyId String
  userId     String
  property   Property @relation(fields: [propertyId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  rating     Int
  content    String?  @db.Text
  isAnonymous Boolean @default(false)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([propertyId, userId])
  @@index([propertyId])
  @@map("reviews")
}
