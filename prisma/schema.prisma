// prisma/schema.prisma
// 小蝸出租 統一資料庫 Schema（網站 + LINE Bot 共用）

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// 網站使用者 (租客 + 房東 + 管理員)
// ─────────────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  phone         String?   @unique
  passwordHash  String?
  role          UserRole  @default(TENANT)

  name          String
  handle        String?   @unique
  avatar        String?
  bio           String?
  lineId        String?
  verified      Boolean   @default(false)

  totalListings Int       @default(0)
  avgRating     Float?
  reviewCount   Int       @default(0)
  yearsActive   Int       @default(0)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  properties    Property[]
  favorites     Favorite[]
  sentMessages  Message[]     @relation("SentMessages")
  receivedMessages Message[]  @relation("ReceivedMessages")
  bookingsAsTenant Booking[]  @relation("TenantBookings")
  reviews       Review[]
  accounts      Account[]
  sessions      Session[]

  @@index([email])
  @@index([handle])
  @@index([role])
  @@map("users")
}

enum UserRole {
  TENANT
  LANDLORD
  ADMIN
}

// ─────────────────────────────────────────────
// 房東（獨立租戶，多房東架構核心）
// 每個房東有自己的後台、房源、用戶、未來綁自己的 LINE Bot
// ─────────────────────────────────────────────
model Landlord {
  id            String    @id @default(cuid())
  name          String                          // 房東名稱（後台顯示）
  email         String    @unique               // 登入帳號
  passwordHash  String                          // 登入密碼（bcrypt）
  phone         String?
  avatar        String?

  // 後台存取金鑰：adminKey 為舊版明文欄位，登入成功後會遷移到 adminKeyHash 並清空
  adminKey      String?   @unique
  adminKeyHash  String?   @unique

  // 階段 B 預留：房東自己的 LINE Bot 設定
  lineChannelSecret      String?
  lineChannelToken       String?
  lineBotName            String?
  lineOfficialId         String?   // LINE 官方帳號 Basic ID / Premium ID（例：@xiaowo）
  notifyLineUserId       String?   // 房東接收預約/維修通知的 LINE User ID
  richMenuConfig         String?   @db.Text   // 圖文選單設定（JSON）
  richMenuId             String?   // 已套用的 LINE Rich Menu ID
  richMenuEnabled        Boolean   @default(false)  // 選單是否開啟
  siteName               String?   // 房東官網名稱
  siteLogo               String?   // 房東官網 LOGO 圖片網址
  botTextConfig          String?   @db.Text   // Bot 自訂文字（JSON）
  botEnabled             Boolean   @default(true)   // Bot 是否啟用
  features               String?   @db.Text   // 功能模組開關（JSON）
  socialConfig           String?   @db.Text   // 社群媒體串接設定（JSON：instagram/facebook/threads 帳號與權杖）
  source                 String    @unique @default(cuid())  // 該房東用戶的來源標記

  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  properties    Property[]
  tenants       Tenant[]
  bookings      Booking[]
  repairs       Repair[]
  communities   Community[]
  managedProperties ManagedProperty[]

  @@index([email])
  @@index([adminKey])
  @@index([adminKeyHash])
  @@map("landlords")
}

// ─────────────────────────────────────────────
// LINE Bot 用戶（從 LINE 官方帳號來的用戶）
// ─────────────────────────────────────────────
model Tenant {
  id            String    @id @default(cuid())
  lineUserId    String
  name          String?
  customName    String?                      // 房東自訂備註名稱
  avatarUrl     String?
  statusMessage String?
  phone         String?
  propertyId    String?
  moveInDate    DateTime?
  rentDue       Int       @default(5)        // 每月幾號繳租
  isActive      Boolean   @default(true)
  source        String    @default("main")   // Bot 來源鍵（主 Bot=main；房東 Bot=landlordId）
  landlordId    String?                       // 歸屬房東
  createdAt     DateTime  @default(now())

  landlord   Landlord? @relation(fields: [landlordId], references: [id])
  property   Property? @relation("TenantResidence", fields: [propertyId], references: [id])
  bookings   Booking[]
  repairs    Repair[]

  @@index([landlordId])
  @@unique([lineUserId, source])
}

// ─────────────────────────────────────────────
// NextAuth (OAuth)
// ─────────────────────────────────────────────
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("sessions")
}

// ─────────────────────────────────────────────
// 房源（網站刊登 + Bot 查詢共用）
// ─────────────────────────────────────────────
model Property {
  id          String         @id @default(cuid())
  landlordId  String
  landlord    User           @relation(fields: [landlordId], references: [id])

  ownerId     String?                          // 多房東架構：歸屬的 Landlord
  owner       Landlord?      @relation(fields: [ownerId], references: [id])

  title       String
  type        PropertyType
  status      PropertyStatus @default(PENDING)
  featured     Boolean       @default(false)  // 主站精選（總管理員控制，未來廣告欄位）
  siteFeatured Boolean       @default(false)  // 房東官網精選（房東自己控制，與 featured 分開）
  description String         @db.Text

  city        String
  district    String
  address     String
  lat         Float?
  lng         Float?

  size        Float
  floor       String?
  totalFloors Int?

  price       Int
  deposit     String         @default("兩個月")
  mgmtFee     Int            @default(0)

  inclWifi    Boolean        @default(false)
  inclWater   Boolean        @default(false)
  inclCable   Boolean        @default(false)

  electricType  String?      // 電費計算方式：'meter'=台電度數, 'flat'=固定金額, 'included'=含在租金
  electricRate  Float?       // 每度電費（electricType=meter 時使用）
  electricFlat  Int?         // 固定電費金額（electricType=flat 時使用）
  cleaningFee   Int?         // 清潔費

  allowPets   Boolean        @default(false)
  allowCook   Boolean        @default(false)
  allowShortTerm Boolean     @default(false)
  welcomeStudent Boolean     @default(true)

  boostPlan   BoostPlan      @default(NONE)
  boostUntil  DateTime?

  viewCount   Int            @default(0)
  favoriteCount Int          @default(0)

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  deletedAt   DateTime?

  images      PropertyImage[]
  amenities   PropertyAmenity[]
  tags        PropertyTag[]
  favorites   Favorite[]
  bookings    Booking[]
  reviews     Review[]
  messages    Message[]
  lineTenants Tenant[]       @relation("TenantResidence")
  repairs     Repair[]

  communityId String?
  community   Community?     @relation(fields: [communityId], references: [id])

  @@index([landlordId])
  @@index([ownerId])
  @@index([city, district])
  @@index([status])
  @@index([price])
  @@index([type])
  @@index([featured])
  @@index([siteFeatured])
  @@map("properties")
}

// ─────────────────────────────────────────────
// 社區（房源群組）
// ─────────────────────────────────────────────
model Community {
  id          String     @id @default(cuid())
  ownerId     String?
  owner       Landlord?  @relation(fields: [ownerId], references: [id])
  name        String
  description String     @default("") @db.Text
  photos      String     @default("[]") @db.Text
  mapUrl      String?
  properties  Property[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("communities")
}

// ─────────────────────────────────────────────
// 網站全域設定（logo、輪播圖等）
// ─────────────────────────────────────────────
model SiteSetting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @default(now()) @updatedAt

  @@map("site_settings")
}

enum PropertyType {
  SUITE
  ROOM
  WHOLE_FLOOR
  SHARED_SUITE
  STUDIO
  STORE
  OFFICE
  LIVE_OFFICE
  FACTORY
  PARKING
  LAND
  OTHER
}

enum PropertyStatus {
  PENDING
  AVAILABLE
  RENTED
  PAUSED
  REJECTED
  COMING_SOON
  INACTIVE
}

enum BoostPlan {
  NONE
  BASIC
  PREMIUM
}

// ─────────────────────────────────────────────
// 房源照片
// ─────────────────────────────────────────────
model PropertyImage {
  id          String   @id @default(cuid())
  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  url         String
  cloudinaryId String?
  order       Int      @default(0)
  isCover     Boolean  @default(false)
  width       Int?
  height      Int?

  createdAt   DateTime @default(now())

  @@index([propertyId])
  @@map("property_images")
}

// ─────────────────────────────────────────────
// 房源設施
// ─────────────────────────────────────────────
model PropertyAmenity {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  name       String

  @@unique([propertyId, name])
  @@index([propertyId])
  @@map("property_amenities")
}

// ─────────────────────────────────────────────
// 房源標籤（可租補、免仲介費等行銷標籤）
// ─────────────────────────────────────────────
model PropertyTag {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  name       String   // 例：'可租補', '免仲介費', '獨洗曬', '垃圾代收', '機車位'

  @@unique([propertyId, name])
  @@index([propertyId])
  @@map("property_tags")
}

// ─────────────────────────────────────────────
// 收藏
// ─────────────────────────────────────────────
model Favorite {
  id         String   @id @default(cuid())
  userId     String
  propertyId String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, propertyId])
  @@index([userId])
  @@map("favorites")
}

// ─────────────────────────────────────────────
// 看房預約（網站用戶 或 LINE 用戶皆可預約）
// ─────────────────────────────────────────────
model Booking {
  id         String        @id @default(cuid())
  propertyId String
  property   Property      @relation(fields: [propertyId], references: [id])

  // 網站用戶（二擇一）
  tenantId   String?
  tenant     User?         @relation("TenantBookings", fields: [tenantId], references: [id])

  // LINE 用戶（二擇一）
  lineUserId String?
  lineUser   Tenant?       @relation(fields: [lineUserId], references: [id])

  date       DateTime
  timeslot   String        // "14:00" 或 "10:00-11:00"
  status     BookingStatus @default(PENDING)
  note       String?
  rejectReason String?

  // 網頁訪客預約（不需登入）
  visitorName   String?
  visitorPhone  String?
  visitorLineId String?
  landlordId String?                       // 歸屬房東
  landlord   Landlord?     @relation(fields: [landlordId], references: [id])

  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([propertyId])
  @@index([tenantId])
  @@index([lineUserId])
  @@index([landlordId])
  @@index([status])
  @@map("bookings")
}

enum BookingStatus {
  PENDING
  CONFIRMED
  REJECTED
  CANCELLED
  COMPLETED
}

// ─────────────────────────────────────────────
// 維修回報（LINE Bot）
// ─────────────────────────────────────────────
model Repair {
  id          String       @id @default(cuid())
  lineUserId  String
  propertyId  String
  title       String
  description String
  status      RepairStatus @default(PENDING)
  photoUrl    String?
  landlordId  String?                      // 歸屬房東
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  lineUser    Tenant   @relation(fields: [lineUserId], references: [id])
  property    Property @relation(fields: [propertyId], references: [id])
  landlord    Landlord? @relation(fields: [landlordId], references: [id])

  @@index([lineUserId])
  @@index([propertyId])
  @@index([landlordId])
  @@map("repairs")
}

enum RepairStatus {
  PENDING
  IN_PROGRESS
  DONE
}

// ─────────────────────────────────────────────
// 站內訊息（網站，預留功能）
// ─────────────────────────────────────────────
model Message {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  propertyId String?

  sender     User     @relation("SentMessages", fields: [senderId], references: [id])
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
  property   Property? @relation(fields: [propertyId], references: [id])

  content    String   @db.Text
  readAt     DateTime?
  createdAt  DateTime @default(now())

  @@index([senderId])
  @@index([receiverId])
  @@index([propertyId])
  @@map("messages")
}

// ─────────────────────────────────────────────
// 評價（網站，預留功能）
// ─────────────────────────────────────────────
model Review {
  id         String   @id @default(cuid())
  propertyId String
  userId     String
  property   Property @relation(fields: [propertyId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  rating     Int
  content    String?  @db.Text
  isAnonymous Boolean @default(false)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([propertyId, userId])
  @@index([propertyId])
  @@map("reviews")
}

// ═══════════════════════════════════════════════════════════════
// 包租代管系統
// ═══════════════════════════════════════════════════════════════

// 委託物業（屋主把房子委託給平台包租或代管）
model ManagedProperty {
  id            String    @id @default(cuid())
  landlordId    String    // 所屬管理者（平台/代管公司，對應 Landlord）
  landlord      Landlord  @relation(fields: [landlordId], references: [id], onDelete: Cascade)

  // 屋主資訊
  ownerName     String    // 屋主姓名
  ownerPhone    String?   // 屋主電話
  ownerEmail    String?   // 屋主 email
  ownerBankName String?   // 屋主匯款銀行（選單）
  ownerBank     String?   // 屋主匯款帳號（撥款用）

  // 物業資訊
  title         String    // 社區名稱
  address       String    // 地址
  roomCount     Int       @default(1)  // 房間數

  // 委託類型與合約
  manageType    String    // 'SUBLEASE'(包租) 或 'TRUST'(代管)
  contractStart DateTime? // 合約起日
  contractEnd   DateTime? // 合約迄日

  // 包租：平台向屋主承租的成本（每月付給屋主的固定金額）
  leaseCost     Int       @default(0)

  // 代管服務費：feePercent 為百分比（N%）
  feeType       String    @default("PERCENT")  // 'PERCENT'(抽成) 或 'FIXED'(固定)；目前代管固定用 PERCENT
  feePercent    Float     @default(10)          // 代管服務費 %
  feeFixed      Int       @default(0)           // 保留（舊欄位）

  // 包租服務費：類型(半個月/一個月/其他) + 其他自填金額
  subleaseFeeType  String?  // 'HALF_MONTH' / 'ONE_MONTH' / 'OTHER'
  subleaseFeeOther Int      @default(0)  // subleaseFeeType=OTHER 時的金額

  // 預期租金收入（保留，目前表單已不顯示）
  expectedRent  Int       @default(0)

  status        String    @default("ACTIVE")    // ACTIVE / ENDED / PAUSED
  note          String?   @db.Text

  // 委託合約條款
  deposit       Int       @default(0)    // 押金
  payDay        Int?      // 每月付款日（1-31）
  payMethod     String?   // 付款方式（轉帳/現金/支票...）
  contractFile  String?   // 委託合約文件 URL（Cloudinary）

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  incomes       ManagementRecord[]
  payouts       OwnerPayout[]
  leases        Lease[]

  @@index([landlordId])
  @@index([manageType])
  @@map("managed_properties")
}

// 收支明細（每筆收入或支出）
model ManagementRecord {
  id                 String          @id @default(cuid())
  managedPropertyId  String
  managedProperty    ManagedProperty @relation(fields: [managedPropertyId], references: [id], onDelete: Cascade)
  leaseId            String?
  lease              Lease?          @relation(fields: [leaseId], references: [id], onDelete: SetNull)
  payoutId           String?
  payout             OwnerPayout?    @relation(fields: [payoutId], references: [id], onDelete: SetNull)

  type        String    // 'INCOME'(收入：租金) 或 'EXPENSE'(支出：維修/雜支)
  category    String    // 'RENT'(租金) / 'REPAIR'(維修) / 'UTILITY'(水電) / 'OTHER'(其他)
  amount      Int       // 金額
  recordDate  DateTime  // 發生日期
  description String?   // 說明
  createdAt   DateTime  @default(now())

  @@index([managedPropertyId])
  @@index([leaseId])
  @@index([payoutId])
  @@index([recordDate])
  @@map("management_records")
}

// 屋主撥款紀錄（每月該撥給屋主多少、是否已付）
model OwnerPayout {
  id                 String          @id @default(cuid())
  managedPropertyId  String
  managedProperty    ManagedProperty @relation(fields: [managedPropertyId], references: [id], onDelete: Cascade)

  period      String    // 帳期，格式 'YYYY-MM'
  grossRent   Int       @default(0)  // 該期收到的租金總額
  mgmtFee     Int       @default(0)  // 扣除的管理費
  expenses    Int       @default(0)  // 扣除的支出（維修等）
  payoutAmount Int      @default(0)  // 實際撥給屋主的金額
  status      String    @default("PENDING")  // PENDING(未付) / PAID(已付)
  paidDate    DateTime? // 撥款日期
  note        String?
  createdAt   DateTime  @default(now())
  records     ManagementRecord[]

  @@unique([managedPropertyId, period])
  @@index([managedPropertyId])
  @@map("owner_payouts")
}

// 租賃合約（平台/屋主 ↔ 租客）
model Lease {
  id                 String          @id @default(cuid())
  managedPropertyId  String
  managedProperty    ManagedProperty @relation(fields: [managedPropertyId], references: [id], onDelete: Cascade)

  // 租客資訊
  tenantName    String    // 承租人姓名
  tenantPhone   String?   // 承租人電話
  tenantIdNo    String?   // 身分證字號（選填）
  lineUserId    String?   // 綁定的 LINE 用戶 ID（推播提醒用）
  propertyId    String?   // 連接的網站房源 ID

  // 租約條款
  roomLabel     String?   // 房號/單位（如：A 房、3 樓）
  rent          Int       @default(0)    // 月租金（原價）
  discountType  String    @default("NONE")  // NONE / FIXED(折固定金額) / PERCENT(折%數)
  discountValue Float     @default(0)        // FIXED=折扣金額；PERCENT=折扣百分比
  deposit       Int       @default(0)    // 押金
  payDay        Int?      // 每月付款日（1-31）
  payMethod     String?   // 付款方式
  paymentCycle  String    @default("MONTHLY") // MONTHLY / BIMONTHLY / QUARTERLY / SEMIANNUAL / YEARLY
  paymentDueMode String   @default("FIXED_DAY") // FIXED_DAY / CONTRACT_START
  leaseStart    DateTime? // 租約起日
  leaseEnd      DateTime? // 租約迄日

  contractFile  String?   // 租約文件 URL（Cloudinary）
  status        String    @default("ACTIVE")  // ACTIVE(生效) / ENDED(已終止) / EXPIRED(已到期)
  note          String?   @db.Text

  // 租客 LINE 綁定（推播提醒用）
  lineTenantId  String?   // 對應 Tenant.id（已加 Bot 的租客）

  // 繳費提醒設定
  rentPayDay    Int       @default(5)      // 每月幾號繳租
  rentRemindOn  Boolean   @default(true)   // 是否推播租金提醒
  utilPayDay    Int?      // 水電繳費日（每月幾號，null=不提醒）
  utilRemindOn  Boolean   @default(false)  // 是否推播水電提醒
  utilAmount    Int       @default(0)      // 水電金額（固定費率金額，或按表計算後的金額）
  lastRentRemind  DateTime?  // 上次推租金提醒的時間（避免同月重複推）
  lastUtilRemind  DateTime?  // 上次推水電提醒的時間

  // 水電費率模式：FIXED(固定費率) / METER(台水台電・按電表度數)
  utilMode      String    @default("FIXED")
  meterReadDate DateTime? // 抄錶時間
  meterCurrent  Int       @default(0)  // 本期度數
  meterNext     Int       @default(0)  // 下期度數
  meterRate     Float     @default(0)  // 每度費率（元）

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  records       ManagementRecord[]
  utilityReadings UtilityReading[]
  rentPayments  RentPayment[]

  @@index([managedPropertyId])
  @@index([leaseEnd])
  @@index([status])
  @@map("leases")
}

model RentPayment {
  id          String   @id @default(cuid())
  leaseId     String
  lease       Lease    @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  recordId    String?

  periodStart DateTime
  periodEnd   DateTime
  dueDate     DateTime
  amount      Int      @default(0)
  paidAmount  Int      @default(0)
  paidDate    DateTime?
  payMethod   String?
  receiptUrl  String?
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([leaseId])
  @@index([dueDate])
  @@map("rent_payments")
}

model UtilityReading {
  id          String   @id @default(cuid())
  leaseId     String
  lease       Lease    @relation(fields: [leaseId], references: [id], onDelete: Cascade)

  startDate   DateTime?
  startDegree Int      @default(0)
  endDate     DateTime
  endDegree   Int
  usedDegree  Int      @default(0)
  rate        Float    @default(0)
  amount      Int      @default(0)
  dueDate     DateTime?
  paidAmount  Int      @default(0)
  paidDate    DateTime?
  payMethod   String?
  receiptUrl  String?
  note        String?
  createdAt   DateTime @default(now())

  @@index([leaseId])
  @@index([endDate])
  @@map("utility_readings")
}
